# deploy/env/cloud.env.example
TZ=America/Chicago

# App
CLOUD_API_PORT=8000
SEED_SITEARRAY_NAME=TEST
SCHEMA_VERSION=ss_v1

# NATS
NATS_URL=nats://nats:4222

# Postgres connectivity
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ss
POSTGRES_USER=ss
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis connectivity
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=3

EMBED_SECRET=CHANGE_ME
PORTFOLIO_LOCK_ENABLED=true
