# deploy/env/daq-ui.env.example



# Browser calls same public host. Nginx routes /api/* to cloud-api.
# Leave blank for same-origin calls like /api/layout.
NEXT_PUBLIC_CLOUD_API_BASE=

NEXT_PUBLIC_BOOTSTRAP_HEALTH=/health
NEXT_PUBLIC_DOCK_FRAME_ID=daq-dock
NEXT_PUBLIC_DOCK_ORIGIN=https://fullstackjedi.dev

EMBED_SECRET=CHANGE_ME
PORTFOLIO_LOCK_ENABLED=true